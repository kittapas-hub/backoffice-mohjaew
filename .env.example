NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_BOOKING_NOTIFY_GROUP_ID=
ADMIN_EMAILS=
BOOKING_START_KEYWORDS=จองคิวปรึกษาหมอแจว
# Required for POST /api/bookings. Secret used to HMAC the client IP for the
# DB-backed rate limit (no raw IP is stored). If missing, the endpoint returns
# a 500 config error instead of silently disabling the rate limit.
BOOKING_RATE_LIMIT_SECRET=
# Required ONLY if you enable the expire cron (/api/cron/expire-bookings).
# The endpoint always requires this token (Authorization: Bearer <CRON_SECRET>);
# if it is left empty the endpoint is disabled and returns 503 (never public).
CRON_SECRET=

# Payment instructions shown on /booking/success (all fields must be filled for
# the payment card to appear; otherwise a safe fallback message is shown).
# Place the QR code image at public/payment-qr.png (see README §11).
BOOKING_PAYMENT_AMOUNT_THB=
BOOKING_BANK_NAME=
BOOKING_ACCOUNT_NAME=
BOOKING_ACCOUNT_NUMBER=
# Path to the QR image served from public/ — e.g. /payment-qr.png
BOOKING_PAYMENT_QR_PATH=/payment-qr.png
# LINE OA URL for customers to send payment slips — e.g. https://line.me/R/ti/p/@youroa
NEXT_PUBLIC_LINE_OA_URL=
