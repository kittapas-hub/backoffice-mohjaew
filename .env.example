NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_BOOKING_NOTIFY_GROUP_ID=
ADMIN_EMAILS=
# Required for POST /api/bookings, POST /api/bookings/face-upload and
# GET /api/slots. Secret used to HMAC the client IP for the DB-backed rate
# limit (no raw IP is stored). If missing, these endpoints return a 500 config
# error instead of silently disabling the rate limit.
BOOKING_RATE_LIMIT_SECRET=
# Optional. Minutes a pending_payment booking holds its seat while waiting for
# payment (default 30, clamped to 5–120). Trade-off: shorter frees unpaid seats
# faster but risks "paid but expired" — the customer transfers near the
# deadline, the hold lapses before the slip is checked, and the expired booking
# cannot be confirmed. Keep >= 30 while payment verification is manual.
BOOKING_HOLD_MINUTES=30
# Required ONLY if you enable the expire cron (/api/cron/expire-bookings).
# The endpoint always requires this token (Authorization: Bearer <CRON_SECRET>);
# if it is left empty the endpoint is disabled and returns 503 (never public).
CRON_SECRET=

# Kill switch for the team-notification delivery worker
# (/api/cron/deliver-notifications, Phase 1A). Only the literal string "true"
# enables delivery; any other value (including unset) is a 200 no-op that
# claims nothing. MUST stay false until the notification_deliveries backlog
# has been reviewed (see README §"Delivery worker — team notifications").
OUTBOX_DELIVERY_ENABLED=false

# Payment instructions shown on /booking/success (all fields must be filled for
# the payment card to appear; otherwise a safe fallback message is shown).
# Place the QR code image at public/payment-qr.png (see README §11).
BOOKING_PAYMENT_AMOUNT_THB=
BOOKING_BANK_NAME=
BOOKING_ACCOUNT_NAME=
BOOKING_ACCOUNT_NUMBER=
# Path to the QR image served from public/ — e.g. /payment-qr.png
BOOKING_PAYMENT_QR_PATH=/payment-qr.png
# LINE OA URL for customers to send payment slips — e.g. https://line.me/R/ti/p/@youroa
NEXT_PUBLIC_LINE_OA_URL=

# ── Automatic slip verification (Phase 1, EasySlip) ──────────────────────────
# ALL THREE of EASYSLIP_API_KEY, SLIP_RECEIVER_ACCOUNTS and
# BOOKING_PAYMENT_AMOUNT_THB must be set for automatic verification to be
# offered; otherwise the flow falls back to the manual LINE slip review.
# SERVER-ONLY: never expose these with a NEXT_PUBLIC_ prefix.
#
# EasySlip API key from https://developer.easyslip.com (placeholder only —
# never commit a real key).
EASYSLIP_API_KEY=
# Comma-separated masked receiver account values EXACTLY as EasySlip reports
# them for the shop's receiving account (bank account and/or PromptPay proxy
# forms). Capture them once by verifying a real inbound slip. Example:
#   SLIP_RECEIVER_ACCOUNTS=xxx-x-x1234-x,xxx-xxx-5678
# Empty = automatic verification fails closed (nothing auto-confirms).
SLIP_RECEIVER_ACCOUNTS=
# Optional comma-separated receiver display names (Thai/English). When set
# AND the slip carries a receiver name, the name must also match.
SLIP_RECEIVER_NAMES=
